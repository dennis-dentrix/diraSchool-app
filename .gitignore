# ── Dependencies ─────────────────────────────────────────────
node_modules/

# ── Environment variables (never commit secrets) ─────────────
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production
.env.staging
.env.production.example

# ── Logs (keep the directory, ignore the files) ──────────────
apps/api/logs/*.log
apps/api/logs/*.log.*
# Keep the directory itself tracked
!apps/api/logs/.gitkeep

# ── Build outputs ────────────────────────────────────────────
dist/
build/
.next/

# ── Test coverage ────────────────────────────────────────────
coverage/

# ── OS / Editor ──────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/settings.json
.idea/

# ── Local credentials / scratch files (never commit) ─────────
logins.txt
nixpacks.toml

# ── MongoDB memory server binary cache ───────────────────────
.mongodb-binaries/
docs/__pycache__/

# ── One-off scripts (safe to delete after use) ───────────────
# Keep folder visible so we can whitelist required scripts.
apps/api/scripts/*
!apps/api/scripts/seed.js
!apps/api/scripts/verify-cloudinary.js
scripts/

# ── Generated analysis documents ─────────────────────────────
*.pdf
EduSaaS-*.md

apps/web/.next

# ── Playwright ────────────────────────────────────────────────────────────────
apps/web/e2e/.auth/*.json
apps/web/playwright-report/
apps/web/test-results/

docs/
